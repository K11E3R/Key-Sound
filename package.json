{
  "name": "key-sound",
  "displayName": "Key Sound",
  "description": "Satisfying keyboard sounds as you write code in VS Code",
  "version": "1.0.0",
  "publisher": "yna",
  "repository": {
    "type": "git",
    "url": "https://github.com/K11E3R/Key-Sound"
  },
  "homepage": "https://github.com/K11E3R/Key-Sound",
  "bugs": {
    "url": "https://github.com/K11E3R/Key-Sound/issues"
  },
  "icon": "icons/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "keywords": [
    "sound",
    "keyboard",
    "audio",
    "typing",
    "mechanical",
    "fun",
    "productivity"
  ],
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "keySoundContainer",
          "title": "Key Sound",
          "icon": "icons/icon.svg"
        }
      ]
    },
    "views": {
      "keySoundContainer": [
        {
          "type": "webview",
          "id": "keySound.settingsView",
          "name": "Key Sound"
        }
      ]
    },
    "commands": [
      {
        "command": "keySound.toggle",
        "title": "Key Sound: Toggle On/Off",
        "icon": "$(unmute)"
      },
      {
        "command": "keySound.setTheme",
        "title": "Key Sound: Change Sound Theme"
      }
    ],
    "configuration": {
      "title": "Key Sound",
      "properties": {
        "keySound.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable keyboard sounds"
        },
        "keySound.theme": {
          "type": "string",
          "enum": [
            "mechanical",
            "typewriter",
            "bubble",
            "soft"
          ],
          "enumDescriptions": [
            "Crisp mechanical keyboard clicks",
            "Classic typewriter clacks",
            "Bubbly popping sounds",
            "Gentle quiet taps"
          ],
          "default": "mechanical",
          "description": "Sound theme"
        },
        "keySound.volume": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.5,
          "description": "Volume level (0 = silent, 1 = maximum)"
        },
        "keySound.playSaveSound": {
          "type": "boolean",
          "default": true,
          "description": "Play a sound when saving a file"
        },
        "keySound.playPasteSound": {
          "type": "boolean",
          "default": true,
          "description": "Play a sound when pasting multi-character text"
        },
        "keySound.playTerminalSound": {
          "type": "boolean",
          "default": true,
          "description": "Play a sound when executing a command in the integrated terminal (requires shell integration)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.93.0",
    "typescript": "^5.3.2"
  }
}
